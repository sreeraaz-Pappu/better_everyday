# Supabase Project URL
# Format: https://<project-ref>.supabase.co
VITE_SUPABASE_URL=

# Supabase Anon/Public Key
# Project Settings -> API -> anon public
VITE_SUPABASE_ANON_KEY=

# Supabase Database URL (server-side only — do NOT prefix with VITE_,
# Vite exposes all VITE_-prefixed vars to the client bundle)
# Format: postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=

# ---- App Login Credentials (Supabase Auth) ----
# The login page asks for a Name instead of an Email. VITE_APP_LOGIN_EMAIL
# is the underlying Supabase Auth account email used behind the scenes when
# the name matches; the password is verified server-side by Supabase Auth.
VITE_APP_LOGIN_EMAIL=
APP_LOGIN_NAME=
APP_LOGIN_PASSWORD=
